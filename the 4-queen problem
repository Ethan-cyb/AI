# Number of queens
print("Enter number of queens: ")
N = int(input())

# Chessboard: NxN matrix initialized with 0
board = [[0]*N for _ in range(N)]

def is_attack(i, j):
    for k in range(N):
        if board[i][k] == 1 or board[k][j] == 1:
            return True

    for k in range(N):
        for l in range(N):
            if (k + l == i + j) or (k - l == i - j):
                if board[k][l] == 1:
                    return True

    return False


def N_queen(n):
    if n == 0:
        return True

    for i in range(N):
        for j in range(N):
            if not is_attack(i, j):
                board[i][j] = 1
                if N_queen(n - 1):
                    return True
                board[i][j] = 0

    return False


# Solve the problem
N_queen(N)

# Print the board
for row in board:
    print(row)









